{
  "name": "@tilty/scaffold-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Tilty backend scaffold.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "db:migrate": "node --import tsx src/scripts/database.ts up",
    "db:rollback": "node --import tsx src/scripts/database.ts down",
    "db:status": "node --import tsx src/scripts/database.ts status",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "npm run clean && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@alicloud/openapi-core": "^1.0.7",
    "@alicloud/sls20201230": "^5.10.1",
    "@koa/cors": "^5.0.0",
    "@koa/router": "^15.6.0",
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "koa": "^3.2.1",
    "koa-bodyparser": "^4.4.1",
    "mysql2": "^3.22.5",
    "node-schedule": "^2.1.1",
    "pg": "^8.21.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8",
    "sqlite3": "^6.0.1",
    "swagger-ui-dist": "^5.32.6",
    "umzug": "^3.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/koa": "^3.0.3",
    "@types/koa__cors": "^5.0.1",
    "@types/koa-bodyparser": "^4.3.13",
    "@types/node": "^25.9.3",
    "@types/node-schedule": "^2.1.8",
    "@types/swagger-ui-dist": "^3.30.6",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
