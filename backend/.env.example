# Runtime mode.
# Options: development, test, production.
# development is the default for local work.
NODE_ENV=development

# HTTP server bind host.
# 0.0.0.0 listens on all network interfaces.
# Use 127.0.0.1 if the server should only accept local machine traffic.
SERVER_HOST=0.0.0.0

# HTTP server port.
SERVER_PORT=3000

# Whether Koa should trust reverse proxy headers.
# Options: true, false.
# Enable only when the backend is behind a trusted reverse proxy.
TRUST_PROXY=false

# Comma-separated CORS allowlist.
# Use the frontend development origin for local work.
CORS_ORIGINS=http://localhost:8011

# Request logging switch.
LOG_REQUEST_ENABLED=true

# Log output targets.
# Options: console, local, sls. Use commas to enable multiple targets.
LOG_TARGETS=console

# Local JSONL log path.
# Used only when LOG_TARGETS includes local.
LOG_LOCAL_PATH=./logs/backend.log

# Aliyun Simple Log Service settings.
# Required only when LOG_TARGETS includes sls.
# LOG_SLS_ENDPOINT=cn-hangzhou.log.aliyuncs.com
# LOG_SLS_PROJECT=tilty-scaffold
# LOG_SLS_LOGSTORE=backend
# LOG_SLS_ACCESS_KEY_ID=
# LOG_SLS_ACCESS_KEY_SECRET=
# LOG_SLS_TOPIC=tilty-scaffold
# LOG_SLS_SOURCE=backend

# In-memory rate limit for authentication-sensitive routes.
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10

# Database driver used by Sequelize.
# Options: sqlite, mysql, postgres.
# This example uses sqlite because it works without a separate database server.
DATABASE_DIALECT=sqlite

# SQLite database file path.
# Used only when DATABASE_DIALECT=sqlite.
# Use :memory: for an in-memory database that is erased when the process exits.
DATABASE_STORAGE=./data/database.sqlite

# Connection URL for MySQL or PostgreSQL.
# Required when DATABASE_DIALECT=mysql or DATABASE_DIALECT=postgres.
# Ignored when DATABASE_DIALECT=sqlite.
#
# MySQL example:
# DATABASE_DIALECT=mysql
# DATABASE_URL=mysql://root:password@localhost:3306/tilty_scaffold
#
# PostgreSQL example:
# DATABASE_DIALECT=postgres
# DATABASE_URL=postgres://postgres:password@localhost:5432/tilty_scaffold

# Sequelize model sync behavior at startup.
# off   = connect without syncing models. Use migrations for schema changes.
# alter = update tables to match models. Intended for local prototype workflows.
# force = drop and recreate synced tables. This deletes data.
# Production requires off.
DATABASE_SYNC=off

# Whether scheduled jobs should be registered and started.
# Options: true, false.
# Use false for tests, maintenance scripts, or API-only local diagnostics.
SCHEDULER_ENABLED=true

# Secret used to sign authentication tokens.
# Use a unique value with at least 32 characters in each environment.
# Production requires this value and must not use the example value.
AUTH_TOKEN_SECRET=development-auth-token-secret-change-before-production

# Email verification service switch.
# Options: off, smtp.
# off  = registration does not require email verification, and password recovery is disabled.
# smtp = registration and password recovery require verification codes sent through SMTP.
EMAIL_VERIFICATION_SERVICE=off

# Email verification timing.
EMAIL_VERIFICATION_CODE_EXPIRES_IN_MS=600000
EMAIL_VERIFICATION_CODE_COOLDOWN_MS=60000

# SMTP delivery settings.
# Required when EMAIL_VERIFICATION_SERVICE=smtp.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_STARTTLS=false
# SMTP_FROM=Tilty Scaffold <noreply@example.com>
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_REQUEST_TIMEOUT_MS=10000

# OIDC single sign-on switch.
# Options: true, false.
SSO_ENABLED=false

# OIDC issuer URL. The backend discovers metadata from:
# ${SSO_ISSUER_URL}/.well-known/openid-configuration
# Required when SSO_ENABLED=true.
# SSO_ISSUER_URL=https://identity.example.com

# OIDC client credentials.
# Required when SSO_ENABLED=true.
# SSO_CLIENT_ID=
# SSO_CLIENT_SECRET=

# Backend callback URL registered with the identity provider.
# Required when SSO_ENABLED=true.
# SSO_REDIRECT_URI=http://localhost:3000/api/auth/sso/callback

# Frontend URL that receives short-lived SSO handoff or bind tokens.
SSO_FRONTEND_CALLBACK_URL=http://localhost:8011/login

# OIDC scopes requested during authorization.
SSO_SCOPES=openid profile email

# OIDC discovery, token exchange, and JWKS request timeout.
SSO_REQUEST_TIMEOUT_MS=10000
