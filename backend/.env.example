# Runtime environment.
# Options: development, test, production.
# Production enables stricter validation for secrets, CORS, and database sync.
NODE_ENV=development

# Whether the setup wizard is locked.
# Options: true, false.
# Missing or false enables setup; true locks setup.
SETUP_LOCKED=true

# HTTP server bind host.
# Use 0.0.0.0 to listen on all network interfaces.
# Use 127.0.0.1 to accept only local machine connections.
SERVER_HOST=0.0.0.0

# HTTP server bind port.
SERVER_PORT=3000

# Whether Koa should trust reverse proxy headers such as X-Forwarded-For.
# Options: true, false.
# Enable only behind a trusted reverse proxy that controls those headers.
TRUST_PROXY=false

# Whether multiple backend instances may run at the same time.
# Options: true, false.
# true requires CACHE_STORE=redis, DATABASE_DIALECT=mysql or postgres, and FILE_STORAGE_DRIVER=oss.
# Scheduler jobs use Redis locks when this and SCHEDULER_ENABLED are true.
MULTI_INSTANCE_ENABLED=false

# Comma-separated CORS origin allowlist.
# Use the frontend origin for local development.
# Production must not include *.
CORS_ORIGINS=http://localhost:8011

# Whether request access logs are written.
# Options: true, false.
LOG_REQUEST_ENABLED=true

# Comma-separated log output targets.
# Options: console, local, sls.
# Use multiple values, such as console,local, when more than one target is needed.
LOG_TARGETS=console

# Local JSONL log file path.
# Used only when LOG_TARGETS includes local.
# Relative paths resolve from the backend application directory.
LOG_LOCAL_PATH=./logs/backend.log

# Maximum number of pending asynchronous log sink writes.
LOG_PENDING_WRITE_MAX=1000

# Maximum time to wait for an asynchronous log sink write, in milliseconds.
LOG_WRITE_TIMEOUT_MS=5000

# Aliyun Simple Log Service endpoint.
# Required only when LOG_TARGETS includes sls.
# LOG_SLS_ENDPOINT=cn-hangzhou.log.aliyuncs.com

# Aliyun Simple Log Service project.
# Required only when LOG_TARGETS includes sls.
# LOG_SLS_PROJECT=tilty-scaffold

# Aliyun Simple Log Service logstore.
# Required only when LOG_TARGETS includes sls.
# LOG_SLS_LOGSTORE=backend

# Aliyun Simple Log Service access key ID.
# Required only when LOG_TARGETS includes sls.
# LOG_SLS_ACCESS_KEY_ID=

# Aliyun Simple Log Service access key secret.
# Required only when LOG_TARGETS includes sls.
# LOG_SLS_ACCESS_KEY_SECRET=

# Aliyun Simple Log Service topic label.
# Used only when LOG_TARGETS includes sls.
# Defaults to tilty-scaffold when omitted.
# LOG_SLS_TOPIC=tilty-scaffold

# Aliyun Simple Log Service source label.
# Used only when LOG_TARGETS includes sls.
# Defaults to backend when omitted.
# LOG_SLS_SOURCE=backend

# Cache backend for cross-request transient state.
# Options: memory, redis.
# Use redis for multi-instance deployments.
# Stores rate limits, token state, email verification state, SSO tokens, scheduler locks, and OIDC metadata.
CACHE_STORE=memory

# Redis connection URL for cache storage.
# Required only when CACHE_STORE=redis.
# Supports redis:// and rediss:// URLs, including an optional non-negative database path.
# CACHE_REDIS_URL=redis://localhost:6379/0

# Redis request timeout in milliseconds.
# Used only when CACHE_STORE=redis.
# Applies to connection establishment and individual cache commands.
CACHE_REDIS_REQUEST_TIMEOUT_MS=10000

# File storage backend for uploaded files.
# Options: local, oss.
# Use oss for multi-instance deployments.
FILE_STORAGE_DRIVER=local

# Maximum accepted avatar upload size in bytes.
# Applies to all file storage drivers.
# Uploads are buffered in the backend process; keep this value conservative.
FILE_UPLOAD_MAX_BYTES=2097152

# Public URL base returned for uploaded files in local storage mode.
# Used only when FILE_STORAGE_DRIVER=local.
# May be a backend-relative path such as /uploads or an absolute public URL.
# Backend-relative paths must begin with a single / and must not use //.
# Absolute public URLs must use HTTPS in production.
# The backend serves local files from the path portion of this value.
# Ignored when FILE_STORAGE_DRIVER=oss; use FILE_OSS_PUBLIC_BASE_URL for OSS public URLs.
FILE_PUBLIC_BASE_URL=/uploads

# Local file storage directory.
# Used only when FILE_STORAGE_DRIVER=local.
# Relative paths resolve from the backend application directory.
FILE_LOCAL_ROOT=./data/uploads

# Aliyun OSS access key ID for uploaded file storage.
# Required only when FILE_STORAGE_DRIVER=oss.
# FILE_OSS_ACCESS_KEY_ID=

# Aliyun OSS access key secret for uploaded file storage.
# Required only when FILE_STORAGE_DRIVER=oss.
# FILE_OSS_ACCESS_KEY_SECRET=

# Aliyun OSS bucket name for uploaded file storage.
# Required only when FILE_STORAGE_DRIVER=oss.
# FILE_OSS_BUCKET=tilty-scaffold

# Aliyun OSS endpoint for the bucket.
# Required only when FILE_STORAGE_DRIVER=oss.
# Example: oss-cn-hangzhou.aliyuncs.com
# FILE_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# Aliyun OSS region for request signing.
# Required only when FILE_STORAGE_DRIVER=oss.
# Example: oss-cn-hangzhou
# FILE_OSS_REGION=oss-cn-hangzhou

# Public URL base returned for uploaded files in OSS storage mode.
# Used only when FILE_STORAGE_DRIVER=oss.
# Set this to a CDN or custom domain when one fronts the bucket.
# Backend-relative paths must begin with a single / and must not use //.
# Absolute public URLs must use HTTPS in production.
# When omitted, URLs default to https://<bucket>.<endpoint>/<object-key>.
# FILE_OSS_PUBLIC_BASE_URL=https://cdn.example.com

# Rate limit window for authentication-sensitive routes, in milliseconds.
AUTH_RATE_LIMIT_WINDOW_MS=60000

# Maximum requests allowed per rate limit window for authentication-sensitive routes.
AUTH_RATE_LIMIT_MAX=10

# Global per-IP rate limit window, in milliseconds.
# Health checks and CORS preflight requests are excluded.
GLOBAL_RATE_LIMIT_WINDOW_MS=60000

# Maximum requests allowed per IP in the global rate limit window.
GLOBAL_RATE_LIMIT_MAX=1000

# Database driver used by Sequelize.
# Options: sqlite, mysql, postgres.
# sqlite is intended for local development or single-instance lightweight deployments.
# Use mysql or postgres for multi-instance deployments.
DATABASE_DIALECT=sqlite

# SQLite database file path.
# Used only when DATABASE_DIALECT=sqlite.
# Use :memory: for a database that is erased when the process exits.
# Relative paths resolve from the backend application directory.
DATABASE_STORAGE=./data/database.sqlite

# Connection URL for MySQL or PostgreSQL.
# Required when DATABASE_DIALECT=mysql or DATABASE_DIALECT=postgres.
# Ignored when DATABASE_DIALECT=sqlite.
#
# MySQL example:
# DATABASE_DIALECT=mysql
# DATABASE_URL=mysql://root:password@localhost:3306/tilty_scaffold
#
# PostgreSQL example:
# DATABASE_DIALECT=postgres
# DATABASE_URL=postgres://postgres:password@localhost:5432/tilty_scaffold

# Database connection timeout in milliseconds.
# Used only when DATABASE_DIALECT is mysql or postgres.
DATABASE_CONNECT_TIMEOUT_MS=10000

# Database connection pool settings.
# Used only when DATABASE_DIALECT is mysql or postgres.
# Total connections across backend instances must stay below the database limit.
DATABASE_POOL_MAX=10
DATABASE_POOL_MIN=0
DATABASE_POOL_ACQUIRE_MS=30000
DATABASE_POOL_IDLE_MS=10000

# Whether database SSL should be enabled.
# Used only when DATABASE_DIALECT is mysql or postgres.
# Options: true, false.
DATABASE_SSL=false

# Sequelize model sync behavior at startup.
# Options: off, alter, force.
# off uses the existing schema and is required in production.
# alter updates tables to match models and is intended only for local prototype workflows.
# force drops and recreates synced tables and deletes data.
DATABASE_SYNC=off

# Whether scheduled jobs should be registered and started.
# Options: true, false.
# Use false for tests, maintenance scripts, or API-only diagnostics.
# In multi-instance deployments, Redis locks select one executor per job trigger.
SCHEDULER_ENABLED=true

# Redis lock TTL for scheduled jobs in multi-instance deployments, in milliseconds.
# Used only when MULTI_INSTANCE_ENABLED=true and SCHEDULER_ENABLED=true.
SCHEDULER_LOCK_TTL_MS=300000

# Secret used to sign authentication tokens.
# Must be at least 32 characters.
# Production requires a unique non-example value.
AUTH_TOKEN_SECRET=development-auth-token-secret-change-before-production

# Access token lifetime in seconds.
AUTH_ACCESS_TOKEN_TTL_SECONDS=900

# Refresh token lifetime in seconds.
# Must be greater than AUTH_ACCESS_TOKEN_TTL_SECONDS.
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000

# HttpOnly cookie name for the access token.
AUTH_ACCESS_TOKEN_COOKIE_NAME=tilty_scaffold_access_token

# HttpOnly cookie name for the refresh token.
# Must be different from AUTH_ACCESS_TOKEN_COOKIE_NAME.
AUTH_REFRESH_TOKEN_COOKIE_NAME=tilty_scaffold_refresh_token

# Authentication cookie SameSite policy.
# Options: lax, strict, none.
AUTH_COOKIE_SAME_SITE=lax

# Authentication cookie Secure policy.
# Options: auto, true, false.
# Production requires true. Required when AUTH_COOKIE_SAME_SITE=none.
AUTH_COOKIE_SECURE=auto

# Email verification delivery service.
# Options: off, smtp.
# off disables registration email verification and password recovery.
# smtp sends verification codes through SMTP and requires SMTP_HOST and SMTP_FROM.
EMAIL_VERIFICATION_SERVICE=off

# Email verification code lifetime in milliseconds.
# Used only when EMAIL_VERIFICATION_SERVICE=smtp.
EMAIL_VERIFICATION_CODE_EXPIRES_IN_MS=600000

# Minimum time between verification code sends for the same email and purpose, in milliseconds.
# Used only when EMAIL_VERIFICATION_SERVICE=smtp.
EMAIL_VERIFICATION_CODE_COOLDOWN_MS=60000

# SMTP server host.
# Required only when EMAIL_VERIFICATION_SERVICE=smtp.
# SMTP_HOST=smtp.example.com

# SMTP server port.
# Used only when EMAIL_VERIFICATION_SERVICE=smtp.
# Defaults to 465 when omitted.
# Common values are 465 for implicit TLS and 587 for STARTTLS.
# SMTP_PORT=465

# Whether SMTP should connect with implicit TLS.
# Used only when EMAIL_VERIFICATION_SERVICE=smtp.
# Options: true, false.
# Defaults to true when omitted.
# SMTP_SECURE=true

# Whether SMTP should upgrade the connection with STARTTLS after connecting.
# Used only when EMAIL_VERIFICATION_SERVICE=smtp and SMTP_SECURE=false.
# Options: true, false.
# Defaults to false when omitted.
# SMTP_STARTTLS=false

# Sender address used in verification emails.
# Required only when EMAIL_VERIFICATION_SERVICE=smtp.
# SMTP_FROM=Tilty Scaffold <noreply@example.com>

# SMTP authentication username.
# Optional when EMAIL_VERIFICATION_SERVICE=smtp.
# Must be configured together with SMTP_PASSWORD when SMTP authentication is used.
# SMTP_USERNAME=

# SMTP authentication password.
# Optional when EMAIL_VERIFICATION_SERVICE=smtp.
# Must be configured together with SMTP_USERNAME when SMTP authentication is used.
# SMTP_PASSWORD=

# SMTP request timeout in milliseconds.
# Used only when EMAIL_VERIFICATION_SERVICE=smtp.
# Defaults to 10000 when omitted.
# SMTP_REQUEST_TIMEOUT_MS=10000

# OIDC single sign-on switch.
# Options: true, false.
SSO_ENABLED=false

# OIDC issuer URL.
# Required only when SSO_ENABLED=true.
# A trailing slash is accepted and normalized.
# Production SSO URLs must use HTTPS.
# The backend discovers metadata from ${SSO_ISSUER_URL}/.well-known/openid-configuration.
# Discovered endpoints must use the configured issuer origin.
# SSO_ISSUER_URL=https://identity.example.com

# OIDC client ID.
# Required only when SSO_ENABLED=true.
# SSO_CLIENT_ID=

# OIDC client secret.
# Required only when SSO_ENABLED=true.
# SSO_CLIENT_SECRET=

# Backend callback URL registered with the OIDC provider.
# Required only when SSO_ENABLED=true.
# Must match the provider application callback configuration.
# Production SSO URLs must use HTTPS.
# SSO_REDIRECT_URI=http://localhost:3000/api/auth/sso/callback

# Frontend URL that receives short-lived SSO handoff or bind tokens.
# Used only when SSO_ENABLED=true.
# Production SSO URLs must use HTTPS.
SSO_FRONTEND_CALLBACK_URL=http://localhost:8011/login

# Space-separated OIDC scopes requested during authorization.
# Used only when SSO_ENABLED=true.
SSO_SCOPES=openid profile email

# OIDC discovery, token exchange, and JWKS request timeout in milliseconds.
# Used only when SSO_ENABLED=true.
SSO_REQUEST_TIMEOUT_MS=10000
