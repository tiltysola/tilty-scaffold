{
  "name": "tilty-scaffold",
  "version": "0.1.7",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev:backend & npm run dev:frontend & wait",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "build": "npm run build:shared && npm run build:backend && npm run build:frontend",
    "build:shared": "npm --prefix shared run build",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "npm --prefix backend run build",
    "db:migrate": "npm --prefix backend run db:migrate",
    "db:rollback": "npm --prefix backend run db:rollback",
    "db:status": "npm --prefix backend run db:status",
    "test": "npm run build:shared && npm run test:backend && npm run test:frontend",
    "test:frontend": "npm --prefix frontend run test",
    "test:backend": "npm --prefix backend run test",
    "typecheck": "npm run build:shared && npm run typecheck:backend && npm run typecheck:frontend",
    "typecheck:shared": "npm --prefix shared run typecheck",
    "typecheck:frontend": "npm --prefix frontend run typecheck",
    "typecheck:backend": "npm --prefix backend run typecheck",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "npm --prefix backend run lint",
    "lint:frontend": "npm --prefix frontend run lint",
    "lint:fix": "npm run lint:fix:backend && npm run lint:fix:frontend",
    "lint:fix:backend": "npm --prefix backend run lint:fix",
    "lint:fix:frontend": "npm --prefix frontend run lint:fix",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "fix": "npm run format && npm run lint:fix",
    "fix:backend": "npm --prefix backend run fix",
    "fix:frontend": "npm --prefix frontend run fix",
    "fix:shared": "npm --prefix shared run fix",
    "clean": "npm --prefix shared run clean && npm --prefix backend run clean && npm --prefix frontend run clean",
    "preview:frontend": "npm --prefix frontend run preview",
    "start:backend": "npm --prefix backend run start"
  },
  "devDependencies": {
    "prettier": "^3.8.4"
  }
}
