# Backend API base URL used by the frontend.
# Defaults to http://localhost:3000 when unset.
# A trailing slash is accepted and normalized.
VITE_API_BASE_URL=http://localhost:3000

# localStorage key for frontend session metadata.
# Tokens are stored in backend-managed HttpOnly cookies.
VITE_AUTH_SESSION_STORAGE_KEY=tilty-scaffold.auth.session
